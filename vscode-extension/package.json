{
  "name": "pinodes-orchestra-vscode",
  "displayName": "PiNodes Orchestra",
  "description": "Visual multi-agent pi console orchestrator inside VS Code — graph canvas, live terminals, visible handoffs.",
  "version": "0.2.16",
  "private": false,
  "publisher": "emanubiz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/emanubiz/pinodes-orchestra.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "pi",
    "agents",
    "orchestration",
    "multi-agent",
    "terminal"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pinodesOrchestra",
          "title": "PiNodes Orchestra",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "pinodesOrchestra": [
        {
          "type": "webview",
          "id": "pinodesOrchestra.control",
          "name": "PiNodes Orchestra"
        }
      ]
    },
    "commands": [
      {
        "command": "pinodesOrchestra.open",
        "title": "Open PiNodes Orchestra",
        "category": "PiNodes Orchestra",
        "icon": "$(window)"
      },
      {
        "command": "pinodesOrchestra.restartBackend",
        "title": "Restart Backend",
        "category": "PiNodes Orchestra",
        "icon": "$(debug-restart)"
      },
      {
        "command": "pinodesOrchestra.stopBackend",
        "title": "Stop Backend",
        "category": "PiNodes Orchestra",
        "icon": "$(debug-stop)"
      },
      {
        "command": "pinodesOrchestra.showLogs",
        "title": "Show Backend Logs",
        "category": "PiNodes Orchestra",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "pinodesOrchestra.open",
          "when": "view == pinodesOrchestra.control",
          "group": "navigation@1"
        },
        {
          "command": "pinodesOrchestra.restartBackend",
          "when": "view == pinodesOrchestra.control",
          "group": "navigation@2"
        },
        {
          "command": "pinodesOrchestra.showLogs",
          "when": "view == pinodesOrchestra.control",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "PiNodes Orchestra",
      "properties": {
        "pinodesOrchestra.port": {
          "type": "number",
          "default": 0,
          "markdownDescription": "Port the pinodes-orchestra backend listens on. **`0`** (default) picks the first free port starting at `3847` so each VS Code window gets its own backend. Set an explicit port only when you need a fixed value."
        },
        "pinodesOrchestra.nodeCommand": {
          "type": "string",
          "default": "node",
          "description": "Command used to run the backend (must be a Node.js 22+ runtime on your PATH)."
        },
        "pinodesOrchestra.backendEntry": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the backend entry (backend/dist/index.js). Leave empty to auto-resolve relative to the extension."
        },
        "pinodesOrchestra.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the backend subprocess when the panel opens (if one is not already running)."
        },
        "pinodesOrchestra.token": {
          "type": "string",
          "default": "",
          "description": "Optional shared secret (PINODES_ORCHESTRA_TOKEN). Leave empty for normal local use — only needed for remote/LAN deployments."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle": "node scripts/bundle.mjs",
    "test": "vitest run",
    "vscode:prepublish": "npm run compile && npm run bundle",
    "package": "vsce package",
    "package:linux": "vsce package --target linux-x64",
    "package:win": "vsce package --target win32-x64",
    "package:mac": "vsce package --target darwin-x64",
    "package:mac-arm": "vsce package --target darwin-arm64"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.8.2",
    "vitest": "^3.2.1"
  }
}
