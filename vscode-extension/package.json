{
  "name": "pi-orchestra-vscode",
  "displayName": "Pi Orchestra",
  "description": "Visual multi-agent pi console orchestrator inside VS Code — graph canvas, live terminals, visible handoffs.",
  "version": "0.1.1",
  "private": true,
  "publisher": "pi-orchestra",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "pi",
    "agents",
    "orchestration",
    "multi-agent",
    "terminal"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "piOrchestra",
          "title": "Pi Orchestra",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "piOrchestra": [
        {
          "type": "webview",
          "id": "piOrchestra.control",
          "name": "Pi Orchestra"
        }
      ]
    },
    "commands": [
      {
        "command": "piOrchestra.open",
        "title": "Open Pi Orchestra",
        "category": "Pi Orchestra",
        "icon": "$(window)"
      },
      {
        "command": "piOrchestra.restartBackend",
        "title": "Restart Backend",
        "category": "Pi Orchestra",
        "icon": "$(debug-restart)"
      },
      {
        "command": "piOrchestra.stopBackend",
        "title": "Stop Backend",
        "category": "Pi Orchestra",
        "icon": "$(debug-stop)"
      },
      {
        "command": "piOrchestra.showLogs",
        "title": "Show Backend Logs",
        "category": "Pi Orchestra",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "piOrchestra.open",
          "when": "view == piOrchestra.control",
          "group": "navigation@1"
        },
        {
          "command": "piOrchestra.restartBackend",
          "when": "view == piOrchestra.control",
          "group": "navigation@2"
        },
        {
          "command": "piOrchestra.showLogs",
          "when": "view == piOrchestra.control",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "Pi Orchestra",
      "properties": {
        "piOrchestra.port": {
          "type": "number",
          "default": 3847,
          "markdownDescription": "Port the pi-orchestra backend listens on. **Note:** the bundled frontend resolves its API on the same origin only for the default port `3847`; change this only if you rebuild the frontend with a matching `VITE_API_BASE`."
        },
        "piOrchestra.nodeCommand": {
          "type": "string",
          "default": "node",
          "description": "Command used to run the backend (must be a Node.js 22+ runtime on your PATH)."
        },
        "piOrchestra.backendEntry": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the backend entry (backend/dist/index.js). Leave empty to auto-resolve relative to the extension."
        },
        "piOrchestra.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the backend subprocess when the panel opens (if one is not already running)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.8.2"
  }
}
